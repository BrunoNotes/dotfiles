[core]
    editor = nvim
[init]
    defaultBranch = master
[alias]
    co = checkout
    br = branch
    ci = commit
    st = status
[pull]
    rebase = true

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
